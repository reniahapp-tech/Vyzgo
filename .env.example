# Configuração do Cloudflare R2 (Upload de Imagens)
# Obtenha esses dados no Dashboard do Cloudflare > R2

# 1. ID da sua conta (aparece na url ou na lateral direita do R2)
VITE_R2_ACCOUNT_ID=

# 2. Nome do Bucket que você criou (ex: vitrine-media)
VITE_R2_BUCKET_NAME=

# 3. Credenciais de API S3 (Crie em "Manage R2 API Tokens")
# Permissão: Admin Read & Write
VITE_R2_ACCESS_KEY_ID=
VITE_R2_SECRET_ACCESS_KEY=

# 4. Domínio Público (Opcional, mas recomendado)
# Habilite "Public Access" no bucket ou conecte um domínio customizado
# Exemplo: https://pub-xxxxxxxx.r2.dev
VITE_R2_PUBLIC_DOMAIN=
